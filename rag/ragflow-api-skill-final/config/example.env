# RAGFlow 配置模板
# ⚠️ 注意：此文件包含敏感信息，不要提交到版本控制！

# ============== 必需配置 ==============

# RAGFlow 服务器地址
# 示例：http://192.168.31.72 或 https://ragflow.example.com
RAGFLOW_BASE_URL=http://your-ragflow-server.com

# API Key（在 RAGFlow Web UI 获取）
# 获取路径：登录 → 设置 → API Keys → 创建新 Key
RAGFLOW_API_KEY=your-api-key-here

# ============== 可选配置 ==============

# 默认知识库 ID（查询时可省略 kb_ids 参数）
# 获取方式：在 RAGFlow Web UI 查看知识库详情
RAGFLOW_DEFAULT_KB_ID=your-kb-id

# 请求超时时间（秒）
RAGFLOW_TIMEOUT=30

# 最大重试次数（网络故障时）
RAGFLOW_MAX_RETRIES=3

# ============== 高级配置 ==============

# 是否启用调试日志
RAGFLOW_DEBUG=true

# 代理配置（如需）
# RAGFLOW_PROXY=http://proxy.example.com:8080
